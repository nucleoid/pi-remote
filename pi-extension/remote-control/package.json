{
  "name": "@pragmaticcoder/pi-remote-control",
  "version": "0.1.1",
  "description": "Pi extension for securely pairing the π Remote Android companion app with an active Pi TUI session.",
  "license": "MIT",
  "author": "pragmaticcoder.com",
  "homepage": "https://github.com/nucleoid/pi-remote#readme",
  "bugs": {
    "url": "https://github.com/nucleoid/pi-remote/issues"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nucleoid/pi-remote.git",
    "directory": "pi-extension/remote-control"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "remote-control",
    "android",
    "android-companion",
    "tui",
    "developer-tools",
    "tailscale",
    "wireguard"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://raw.githubusercontent.com/nucleoid/pi-remote/main/docs/screenshots/main.png"
  },
  "scripts": {
    "client": "node client.mjs",
    "test": "node --experimental-strip-types --test index.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "README.md",
    "index.ts",
    "client.mjs"
  ],
  "dependencies": {
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
