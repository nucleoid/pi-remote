{
  "name": "@nucleoid/pi-remote-protocol",
  "version": "0.1.0",
  "description": "Schema-first protocol v3 contracts and codecs for Pi Remote",
  "type": "module",
  "engines": { "node": ">=22" },
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist", "README.md"],
