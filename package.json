{
  "name": "pi-remote",
  "private": true,
  "version": "0.1.0",
  "description": "Repo-root Pi package metadata for installing the π Remote Pi extension from git/local paths.",
  "license": "MIT",
  "author": "pragmaticcoder.com",
  "homepage": "https://github.com/nucleoid/pi-remote#readme",
  "bugs": {
    "url": "https://github.com/nucleoid/pi-remote/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "pi-extension/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "pack:inspect": "npm pack --dry-run && npm pack --dry-run --workspace @nucleoid/pi-remote-protocol && npm pack --dry-run --workspace @nucleoid/pi-remote-daemon && npm pack --dry-run --workspace @pragmaticcoder/pi-remote-control"
  },
  "files": [
    "README.md",
    "LICENSE",
    "pi-extension/remote-control/index.ts",
    "pi-extension/remote-control/bridge.ts",
    "pi-extension/remote-control/identity.ts",
    "pi-extension/remote-control/events.ts",
    "pi-extension/remote-control/outbox.ts",
    "pi-extension/remote-control/controls.ts",
    "pi-extension/remote-control/gates.ts",
    "pi-extension/remote-control/attachments.ts",
    "pi-extension/remote-control/pairing.ts",
    "pi-extension/remote-control/config.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nucleoid/pi-remote.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "remote-control",
    "android",
    "android-companion",
    "tui",
    "developer-tools",
    "tailscale",
    "wireguard"
  ],
  "pi": {
    "extensions": [
      "./pi-extension/remote-control/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/nucleoid/pi-remote/main/docs/screenshots/main.png"
  },
  "dependencies": {
    "@nucleoid/pi-remote-daemon": "0.1.0",
    "@nucleoid/pi-remote-protocol": "0.1.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "typebox": "^1.1.38"
  }
}
